  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Automatically retrieve a fresh token using email and password variables if they are set",
          "const pathString = pm.request.url.getPath() || '';",
          "const bypassAuth = ['login', 'register', 'health'].some(p => pathString.includes(p));",
          "",
          "if (!bypassAuth) {",
          "    const email = pm.collectionVariables.get('email');",
          "    const password = pm.collectionVariables.get('password');",
          "    const baseUrl = pm.collectionVariables.get('baseUrl');",
          "",
          "    if (email && password) {",
          "        pm.sendRequest({",
          "            url: baseUrl + '/api/auth/login',",
          "            method: 'POST',",
          "            header: { 'Content-Type': 'application/json' },",
          "            body: {",
          "                mode: 'raw',",
          "                raw: JSON.stringify({ email: email, password: password })",
          "            }",
          "        }, function (err, res) {",
          "            if (!err && res.code === 200) {",
          "                const responseJson = res.json();",
          "                if (responseJson.access_token) {",
          "                    pm.collectionVariables.set('accessToken', responseJson.access_token);",
          "                }",
          "            }",
          "        });",
          "    }",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
